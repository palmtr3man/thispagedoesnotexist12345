# ============================================================
# The Ultimate Journey — Environment Variables
# Copy this file to .env for local dev (never commit .env)
# Set these in the Netlify dashboard under Site settings > Build & deploy > Environment variables
# ============================================================
#
# Security note:
# - Do not place real secrets in this file.
# - Replace every placeholder below with a value from the source noted in the comment.
#
# Value format convention used here:
#   your-...-here = replace with the real value from the provider dashboard

# --- SendGrid ---
# Fetch from SendGrid Dashboard > Email API > API Keys
SENDGRID_API_KEY=your-sendgrid-api-key-here

# Fetch from SendGrid Dashboard > Email API > Dynamic Templates (template details)
SENDGRID_TEMPLATE_ID=your-sendgrid-template-id-here
SENDGRID_TEMPLATE_ALPHA_FLIGHT_ANNOUNCEMENT=your-alpha-flight-announcement-template-id
SENDGRID_TEMPLATE_BOARDING_CONFIRMATION=your-boarding-confirmation-template-id
SENDGRID_TEMPLATE_VIP_BOARDING_PASS=your-vip-boarding-pass-template-id
SENDGRID_TEMPLATE_VIP_BOARDING_INSTRUCTIONS=your-vip-boarding-instructions-template-id
SENDGRID_UNSUBSCRIBE_URL=https://your-unsubscribe-url.example

# Fetch from your verified SendGrid sender / single sender authentication settings
SENDGRID_FROM_EMAIL=your-verified-sender@example.com

# --- Site / public URLs ---
# Fetch from your deployed site URL in Netlify site settings or your custom domain provider
PLATFORM_URL=https://your-platform-domain.example

# Fetch from the public beehiiv newsletter URL for this publication
SIGNAL_URL=https://your-beehiiv-newsletter.example

# Fetch from the deployed .tech passport / onboarding site URL
PASSPORT_URL=https://your-passport-domain.example

# --- beehiiv (Signal newsletter auto-subscribe) ---
# Fetch from beehiiv Dashboard > Settings > API
BEEHIIV_API_KEY=your-beehiiv-api-key-here

# Fetch from the beehiiv publication settings / API page for the publication ID
BEEHIIV_PUB_ID=

# --- Base44 (seat store / function endpoints) ---
# Fetch from Base44 Dashboard > Code > Functions > seat-request
BASE44_SEAT_REQUEST_URL=your-base44-seat-request-function-url-here

# Fetch from Base44 Dashboard > Code > Functions > getCohortStatus
BASE44_COHORT_STATUS_URL=your-base44-cohort-status-function-url-here

# Fetch from Base44 Dashboard > Code > Functions > Seat entity read endpoint
BASE44_SEAT_URL=your-base44-seat-read-url-here

# Fetch from Base44 Dashboard > Entities > User — read endpoint for resume_fit_check_status enrichment in /api/seat-status (BLOCKER-05-FU)
# Required for BLOCKER-06 UI toggle stateful routing to work correctly.
# Format: https://api.base44.com/api/apps/<APP_ID>/entities/User
BASE44_USER_URL=your-base44-user-read-url-here

# Fetch from Base44 Dashboard > Code > Functions > setDeparture
BASE44_SET_DEPARTURE_URL=your-base44-set-departure-function-url-here

# Optional environment flag used by the seat-status proxy
ALPHA_MODE=your-alpha-mode-flag-here

# --- Notion logging ---
# Fetch from Notion > Settings & members > Connections / My integrations
NOTION_API_KEY=your-notion-integration-secret-here

# Fetch from the Notion database URL for the Seat Request Registry
NOTION_SEAT_REQUEST_DATABASE_ID=your-notion-database-id-here

# --- BMAC (Buy Me a Coffee) ---
BMAC_SUPPORT_URL=https://buymeacoffee.com/theultimatejourney

# --- Zapier webhooks ---
# Fetch from Zapier > Zaps > Webhooks by Zapier catch hook for task-closed events.
ZAPIER_TASK_CLOSED_WEBHOOK_URL=your-zapier-task-closed-webhook-url-here

# --- BLOCKER-08: Alignment Loop (Notion ↔ SaaS) ---
# Scope: Base44 + Supabase + Netlify env vars + Notion field sync
# Cron: every 5 minutes for PAL-21 Application sync (netlify.toml [functions."alignment-loop"] schedule = "*/5 * * * *")
# Webhook: POST /api/alignment-loop with x-internal-token or Authorization Bearer (deploy/gate-change events)
# Policy (locked May 1, 2026):
#   auto-repair  → boarding_emails_sent, resume_fit_check_status
#   manual-review → journey_status, seat_status, identity, billing, schema
# Drift records persist permanently as auditable lifecycle log (no auto-expiry)
# SEC-06 invocation guards (Netlify + Base44)
SEC06_INTERNAL_TOKEN=               # Internal token: x-internal-token or Authorization Bearer
SEC06_SCHEDULER_SECRET=             # Scheduler token: Authorization Bearer or x-scheduler-secret (cron jobs)
NOTION_SECRET=                      # TUJ Alignment Bot integration token — used by alignment-loop.js (same value as NOTION_API_KEY; alignment-loop uses this name per BLOCKER-08 spec)
NOTION_SEAT_DB_ID=                  # Passenger Pipeline DB — confirmed Apr 27, 2026 — value set in Netlify dashboard env vars
NOTION_DRIFT_REPORT_DB_ID=          # TUJ Drift Reports DB — confirmed Apr 27, 2026 — value set in Netlify dashboard env vars
NOTION_JD_PIPELINE_DB_ID=            # PAL-21 JD Pipeline Tracker DB (2dbbc9d7-494c-803d-9670-ec7be3598789)
BASE44_APPLICATION_URL=              # PAL-21 Base44 Application entity endpoint used by /api/alignment-loop polling fallback
SENDGRID_TEMPLATE_SPONSORED_APPROVED=d-7a7628db6a1e4430b1394a069d0438b0
SENDGRID_TEMPLATE_VIP_BOARDING_PASS=d-1e5c7552460444028e37c0f935a9e32f
SENDGRID_TEMPLATE_VIP_BOARDING_INSTRUCTIONS=d-54a2336a46134073b589ec5f698c11f3

# --- Beehiiv Segmentation — Conditional email routing (BEEHIIV-SEG, 2026-05-06) ---
# Both are optional. When set, seat-request.js fires them based on career_stage.
# SENDGRID_TEMPLATE_ALPHA_SEAT_CONFIRM: Seat ID / TUJ code follow-up for Active Job Seekers
#   Tokens: first_name, full_name, seat_id, tuj_code, flight_code, passport_url, platform_url, career_stage
# SENDGRID_TEMPLATE_PREBOARD_NURTURE: Pre-boarding nurture track for Passive Browsers
#   Tokens: first_name, full_name, seat_id, tuj_code, platform_url, signal_url, career_stage
SENDGRID_TEMPLATE_ALPHA_SEAT_CONFIRM=    # d-... — fires when career_stage = 'Active Job Seeker'
SENDGRID_TEMPLATE_PREBOARD_NURTURE=      # d-... — fires when career_stage = 'Passive Browser'
PILOT_TOKEN=

# --- Demo Mission Control / SendGrid fan-out ---
# TUJ-KC2222 is the canonical demo/pilot Seat ID. DEMO_SEAT_IDS lets /api/seat
# validate it even when Base44 is unavailable or the Seat entity has not been
# provisioned yet.
DEMO_SEAT_IDS=TUJ-KC2222
DEMO_SEAT_ID=TUJ-KC2222
DEMO_ACCOUNT_EMAIL=                   # Recipient for /api/demo-sendgrid; never expose client-side
DEMO_FIRST_NAME=Kevin
DEMO_LAST_NAME=Clark
DEMO_FLIGHT_CODE=FL-CG-000
DEMO_SEND_SECRET=                     # Optional override for /api/demo-sendgrid; falls back to SEC06_INTERNAL_TOKEN
SENDGRID_DEMO_DAILY_LIMIT=100         # Hard safety cap for demo template fan-out requests
BASE44_SEAT_LIST_URL=           # Optional Base44 Seat entity list endpoint used by /api/seat-ready and /api/seat-status when available.
ACTIVE_FLIGHT_CODE=FL-CG-000   # Operational flight code for Ready-click seat transactions.
READY_CLICK_SEND_ENABLED=false # Safety gate for /api/seat-ready SendGrid trigger; keep false until QA evidence clears idempotency.
READY_CLICK_PASSENGER_TOKEN= # Optional passenger bearer token for /api/seat-ready; use signed server-issued token, not raw email/passenger_id.
READY_CLICK_IDEMPOTENCY_TABLE=ready_click_idempotency # Supabase REST table with unique idempotency_key for Ready-click write/send serialization.
READY_CLICK_IDEMPOTENCY_GUARD_OPTIONAL=false # Keep false in deployed environments; true only for local smoke tests without Supabase.
SUPABASE_URL= # Required when Ready-click idempotency guard is enforced.
SUPABASE_SERVICE_ROLE_KEY= # Required when Ready-click idempotency guard is enforced; server-side only.
