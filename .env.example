# ============================================================
# The Ultimate Journey — Environment Variables
# Copy this file to .env for local dev (never commit .env)
# Set these in the Netlify dashboard under Site > Environment
# ============================================================

# --- SendGrid ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@thispagedoesnotexist12345.com

# SendGrid template IDs — all resolved via sendgrid-templates.js (single source of truth)
# See Notion: 📧 SendGrid Template Registry — All Templates
SENDGRID_TEMPLATE_SEAT_REQUEST=d-740595dc07be40129569bc731f1bc454          # seat_request_acknowledgement_v1 — fires on /api/seat-request form submit
SENDGRID_TEMPLATE_INTERNAL_SIGNUP=d-073dc68a683348f18133d78c9879ced8        # internalsignupnotification_v1 — internal alert on new signup
SENDGRID_TEMPLATE_NEXT_FLIGHT_WAITLIST=d-52c178a809f94a82a3bf8cd6ebd435e9   # next_flight_waitlist_v1 — fires when gate is closed or flight is full
SENDGRID_TEMPLATE_OPT_OUT_ACK=d-e74bbc76586845f98febdd724cc69429           # optout_acknowledgement_v1 — fires on Active → Paused (F153)
SENDGRID_TEMPLATE_ALPHA_ANNOUNCEMENT=d-a33174bd2e4f4682b5b1546f106fb43c     # alphaflightannouncement_v1 — Phase 2 boarding send 1
SENDGRID_TEMPLATE_BOARDING_CONFIRMATION=d-678824bc506c432dae9eadab36c07904  # boarding_confirmation_v1 — Phase 2 boarding send 2
SENDGRID_TEMPLATE_OFFER_CONGRATS=d-11d5610e48b34eedb77dc2bc7bdf4eaa        # offer_congrats_v1 — fires on handleSeatGraduated (offer received)
SENDGRID_TEMPLATE_EXEC_PREBOARD=d-d8cef7e7bfbc449fa318219bda70d397          # exec_preboard_opentowork_v1 — fires in handleSeatOpened when boarding_type=executive_pre
# Boarding sequence templates (handleSeatOpened fan-out — Fix 1 + Fix 2, Apr 2, 2026)
SENDGRID_TEMPLATE_BOARDING_PASS_FREE=d-91ca65ce16634f299a46af4f0645d540         # boarding_pass_free_v1 — Fix 1: CTA uses {{passport_url}} deep-link with seat_id
SENDGRID_TEMPLATE_BOARDING_PASS_PAID=d-9290e951724f4b028d94945d4f06b69f         # boarding_pass_paid_v1 — Fix 1: CTA uses {{passport_url}} deep-link with seat_id
SENDGRID_TEMPLATE_BOARDING_INSTRUCTIONS_FREE=d-747dac53dd2c4b47b33400376aad1672  # boarding_instructions_free_v1 — Fix 2: CTA uses {{first_task_url}} with seat_id appended
SENDGRID_TEMPLATE_BOARDING_INSTRUCTIONS_PAID=d-d8ec12e940944c5596af1fa740cf7f07  # boarding_instructions_paid_v1 — Fix 2: CTA uses {{first_task_url}} with seat_id appended

# --- Platform URLs ---
PLATFORM_URL=https://www.thispagedoesnotexist12345.com
SIGNAL_URL=https://newsletter.thispagedoesnotexist12345.us
PASSPORT_URL=https://www.thispagedoesnotexist12345.com  # Mission Control base URL — seat_id appended at send time (e.g. ?seat_id=TUJ-XXXXXX)

# --- beehiiv (Signal newsletter auto-subscribe) ---
BEEHIIV_API_KEY=
BEEHIIV_PUB_ID=pub_e3dd6c0b-979c-464c-a7ee-c146e912aadf

# --- Base44 API endpoints ---
# Leave blank to activate graceful stub mode in seat-request.js
BASE44_SEAT_REQUEST_URL=        # Base44 SeatRequest write endpoint (stub until credits return)
BASE44_COHORT_STATUS_URL=       # Base44 getCohortStatus function URL — required for /api/seat-status proxy
BASE44_SEAT_URL=                # Base44 Seat record read/update endpoint — required for sendgrid-integration.js and set-departure.js
BASE44_SEAT_LIST_URL=           # (Optional) Base44 Seat entity list endpoint for active flight — used by /api/seat-status to build the seats[] array (F117). When unset, seats[] is synthesised from getCohortStatus aggregate counts.
BASE44_SET_DEPARTURE_URL=       # Base44 setDeparture function URL — required for /api/set-departure

# --- Netlify (used by Base44 webhook integrations) ---
NETLIFY_API_KEY=                # Personal access token from Netlify User Settings → Applications
NETLIFY_SITE_ID=                # From Netlify → thispagedoesnotexist12345 → Site configuration → General

# --- Notion logging ---
NOTION_API_KEY=
NOTION_SEAT_REQUEST_DATABASE_ID=5e6440af0ad94c6d89a8442ec2c528f3

# --- SendGrid Unsubscribe Groups (ASM) ---
# Group IDs from SendGrid → Suppressions → Unsubscribe Groups
# Required to resolve unsubscribe footer links from raw tags to working preference center
SENDGRID_UNSUBSCRIBE_GROUP_TRANSACTIONAL=33047   # "The Ultimate Journey — Transactional" — wired in seat-request.js ASM block
SENDGRID_UNSUBSCRIBE_GROUP_MARKETING=            # "TUJ Marketing & Updates" — add after creating group in SendGrid dashboard (F152). When set, both groups appear in the preference center.

# --- Feature flags ---
ALPHA_MODE=true                        # Enables Alpha-gated flows (confirmed set in Netlify Mar 24, 2026)
SENDGRID_DEBUG=false                   # Set to "true" to emit structured tuj_email_send JSON log lines per send (success + error). Never logs payload or API key.
SENDGRID_STRICT_TEMPLATE_CHECK=false   # Set to "true" to throw at cold-start if any resolved template ID doesn't match the canonical fallback (catches Netlify env drift)
PUBLIC_GATE_STATE=hold                 # Operator override for public gate state. Injected into /api/seat-status response, overrides Base44 gate_status. Values: open | hold | closed | boarding. Fixes QA #1 (hero label) + QA #6 (CTA suppression). Set in Netlify dashboard -- do not commit a real value here.

# --- F-190: AutoSend (primary email provider) ---
# See Notion: F-190 — AutoSend / SendGrid Parallel Alignment
AUTOSEND_API_KEY=                                                    # AutoSend Bearer token — primary provider for boarding emails
AUTOSEND_TEMPLATE_BOARDING_PASS_FREE=69d1d387f27358a37673e394        # boarding_pass_free_v1 — AutoSend mirror (Apr 4, 2026)
AUTOSEND_TEMPLATE_BOARDING_PASS_PAID=69d1d388f27358a37673e399        # boarding_pass_paid_v1 — AutoSend mirror (Apr 4, 2026)
AUTOSEND_TEMPLATE_BOARDING_INSTRUCTIONS_FREE=69d1d38af27358a37673e39e  # boarding_instructions_free_v1 — AutoSend mirror (Apr 4, 2026)
AUTOSEND_TEMPLATE_BOARDING_INSTRUCTIONS_PAID=69d1d38cf27358a37673e3a3  # boarding_instructions_paid_v1 — AutoSend mirror (Apr 4, 2026)

# --- SendPilot ---
SENDPILOT_API=                                                      # SendPilot API key (sp_live_...) — set in Netlify env vars, scoped to Builds/Functions/Runtime

# --- F-190: Provider routing ---
EMAIL_PRIMARY_PROVIDER=                                              # Set to "sendgrid" to bypass AutoSend and force SendGrid (smoke test / fallback override)
SITE_URL=https://thispagedoesnotexist12345.com                       # Base URL for CTA deep-links in boarding emails (?seat_id= appended per Fix 1 + Fix 2)

# --- BMAC (Buy Me a Coffee) ---
BMAC_SUPPORT_URL=https://buymeacoffee.com/theultimatejourney
