# ============================================================
# The Ultimate Journey — Environment Variables
# Copy this file to .env for local dev (never commit .env)
# Set these in the Netlify dashboard under Site > Environment
# ============================================================

# --- SendGrid ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@thispagedoesnotexist12345.com

# SendGrid template IDs (all active — see Notion: SendGrid Template Registry)
SENDGRID_TEMPLATE_SEAT_REQUEST=d-740595dc07be40129569bc731f1bc454      # seat_request_acknowledgement_v1 — fires on /api/seat-request form submit
SENDGRID_TEMPLATE_NEXT_FLIGHT_WAITLIST=d-52c178a809f94a82a3bf8cd6ebd435e9  # next_flight_waitlist_v1 — fires when gate is closed or flight is full
SENDGRID_TEMPLATE_OPT_OUT_ACKNOWLEDGEMENT=d-e74bbc76586845f98febdd724cc69429 # optout_acknowledgement_v1 — fires on Active → Paused (F153)

# --- Platform URLs ---
PLATFORM_URL=https://www.thispagedoesnotexist12345.com
SIGNAL_URL=https://newsletter.thispagedoesnotexist12345.us
PASSPORT_URL=https://www.thispagedoesnotexist12345.tech  # .tech OnboardingPassport base URL — seat_id appended at send time

# --- beehiiv (Signal newsletter auto-subscribe) ---
BEEHIIV_API_KEY=
BEEHIIV_PUB_ID=pub_e3dd6c0b-979c-464c-a7ee-c146e912aadf

# --- Base44 API endpoints ---
# Leave blank to activate graceful stub mode in seat-request.js
BASE44_SEAT_REQUEST_URL=        # Base44 SeatRequest write endpoint (stub until credits return)
BASE44_COHORT_STATUS_URL=       # Base44 getCohortStatus function URL — required for /api/seat-status proxy
BASE44_SEAT_URL=                # Base44 Seat record read/update endpoint — required for sendgrid-integration.js and set-departure.js
BASE44_SET_DEPARTURE_URL=       # Base44 setDeparture function URL — required for /api/set-departure

# --- Netlify (used by Base44 webhook integrations) ---
NETLIFY_API_KEY=                # Personal access token from Netlify User Settings → Applications
NETLIFY_SITE_ID=                # From Netlify → thispagedoesnotexist12345 → Site configuration → General

# --- Notion logging ---
NOTION_API_KEY=
NOTION_SEAT_REQUEST_DATABASE_ID=5e6440af0ad94c6d89a8442ec2c528f3

# --- SendGrid Unsubscribe Groups (ASM) ---
# Group IDs from SendGrid → Suppressions → Unsubscribe Groups
# Required to resolve unsubscribe footer links from raw tags to working preference center
SENDGRID_UNSUBSCRIBE_GROUP_TRANSACTIONAL=33047   # "The Ultimate Journey — Transactional" — wired in seat-request.js ASM block
SENDGRID_UNSUBSCRIBE_GROUP_MARKETING=            # "TUJ Marketing & Updates" — add after creating group in SendGrid dashboard

# --- Feature flags ---
ALPHA_MODE=true                 # Enables Alpha-gated flows (confirmed set in Netlify Mar 24, 2026)
SENDGRID_DEBUG=false            # Set to "true" to emit structured tuj_sendgrid_send JSON log lines per send (success + error). Never logs payload or API key.

# --- BMAC (Buy Me a Coffee) ---
BMAC_SUPPORT_URL=https://buymeacoffee.com/theultimatejourney
